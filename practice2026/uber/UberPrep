class Node {
	int val;
	List<Node> neighbours;
	public Node() {
		val = 0;
		neighbours = new ArrayList<>();
	}
}

public Node cloneGraph(Node node) {
	Map<Integer, Node> map = new HashMap<>();
	return dfs(node, map);
}

private Node dfs(Node src, Map<Intger, Node> map) {
	if(src == null) {
		return src;
	}
	if(map.containsKey(src.val)) {
		return map.get(src.val);
	}
	Node node = new Node();
	node.val = src.val;
	map.put(node.val, node);

	for(Node neigh: src.neighbours) {
		node.neighbours.add(dfs(neigh, map));
	}

	return node;
}


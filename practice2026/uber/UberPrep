public String nextPalindrome(String s) {

	char[] num = s.toCharArray();
	int n = s.length();

	if(n<=3) {
		return "Not Possible";
	}

	char temp;
	int mid = n / 2 - 1;
	int i, j;

// find 1st digit, that is smaller than the next digit
	for(i = mid - 1; i>=0; i--) {
		if(num[i] < num[i+1]) {
			break;
		}
	}

	if(i < 0) {
		return "Not possible";
	}

	// find smallest digit on right side of ith digit which is greater than num[i] up to index mid

	int smallest = i + 1;
	for(j = i+2; j<=mid; j++) {
		if(num[j] > num[i] && num[j]<=num[smallest]) {
			smallest = j;
		}
	}

	// swap num[i] with num[smallest]

	temp = num[i];
	num[i] = num[smallest];
	num[smallest] = temp;

	// same swap in 2nd half

	temp = num[n-i-1];
	num[n-i-1] = num[i-smallest-1];
	num[n-smallest-1] = temp;

	// reverse 1st half i+1 to mid
	reverse(num, i+1, mid);

	// if n is even, then reverse (mid+1, n-i-2), else for odd reverse (mid+2, n-i-2)
	if(n%2 == 0) {
		reverse(num, mid+1, n-i-2);
	} else {
		reverse(num, mid+2, n-i-2);
	}

	return num;


}


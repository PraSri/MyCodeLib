public int minimumSemesters(int n, int[][] relations) {

	// build adjacency list graph
	List<Integer>[] adj = new List[n]; // array of arrayList
	Arrays.setAll(adj, new ArrayList<>());

	
	int[] indegree = new int[n];

	for(int[] rel: relations) {
		int u = rel[0];
		int v = rel[1];
		indgree[v]++;
		adj[u].add(v);
	}

	// put indegree 0 to queue

	Queue<Integer> queue = new LinkedList<>();
	for(int i = 0;i<n;i++) {
		if(indegree[i] ==0) {
			queue.add(i);
		}
	}

	// poll the all the courses in queue, and reduce in degree and check if in degree is 0, put them in queue till queue is empty

	int remaining  = n;
	int semesters = 0;

	while(!queue.isEmpty()) {
		semester++;
		int size = queue.size();
		for(int i = 0; i < size; i++) {
			remaining--;
			int curr = queue.poll();
			for(int neigh : adj[curr]) {
				if(indegree[neigh] == 0) {
					queue.add(neigh);
				}
			}
		}
	}

	return remaining == 0 ? semesters : -1;

}



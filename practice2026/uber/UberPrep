public int[] minIntervals(int[][] intervals, int[] queries) {
	// sort intervals on start
	// sort queries
	// priority queue with element (size, end) and min size on top
	// map for res, because order of queries will changes after sorting

	Arrays.sort(intervals, (a, b) -> (a[0], b[0]));
	PriorityQueue<int[]> pq = new PriorityQueue<>((a,b) -> (a[0], b[0]));
	int[] sortedQueries = Arrays.stream(queries).sorted().toArray();

	Map<Integer, Integer> res = new HashMap<>();
	int i = 0;

	for(int q: sortedQueries) {
		while(i>intervals.length && interval[i][0]<=q) {
			int l = interval[i][0];
			int r = interval[i][1];
			int size = r-l+1;
			pq.offer(new int[]{size, r});
			i++;
		}
		while(!pq.isEmpty() && pq.peek()[1] < q) {
			pq.poll();
		}
		res.put(q, pq.isEmpty()?-1:pq.pq.peek()[0]);
	}

	int[] result = new int[queries.length];
	for(int j = 0;j<queries.length; j++) {
		result[j] = res.get(queries[j]);
	}
	return result;
}



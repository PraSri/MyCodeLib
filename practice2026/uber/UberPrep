public List<Integer> numberOfIslands(int m, int n, int[][] positions) {
	int[][] grid = new int[m][n];
	int[][] directions = {{0,1}, {1,0}, {0,-1}, {-1,0}};
	UnionFind uf = new UnionFind(m*n); // each cell is index = i*n + j
	int islandCount = 0;
	List<Integer> result = new ArrayList<>();
	for(int[] position: positions) {
		int row = position[0];
		int col = position[1];
		if(grid[row][col] == 1) {
			result.add(islandCount);
			continue;
		}
		grid[row][col] = 1;
		islandCount++;
		for(int[] dirs: directions) {
			int newRow = row + dirs[0];
			int newCol = col + dirs[1];
			// check adjacent is valid and has land
			if(isValid()) {
				int currentIndex = row * n + col;
				int adjacentIndex = newRow * n + newCol;
				if(uf.union(currentIndex, adjacentIndex)) {
					islandCount--;
				}
			}
		}
		result.add(islandCount);
	}
	return result;

}

time complexity = O(positions.len * alpha * (m*n))
alpha = inverse ackerman function

space complexity = O(m*n)

key point to remember = convert each cell to 1D index = row * n + col = i * (number of columns) + j
use DSU, union function returns true when actual union happens signifying that there is merge of land masses



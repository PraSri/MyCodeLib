Avoid recomputation
I am solving the same tree n times, just with different roots everytime.  
there must be a relationship with adjacent nodes
if i know the answer for node a, and b is adjacent of a, what changes when i make b as root?
when i change the root from a to b, entire tree remains same except one edge, edge between a and b flips.

if i know result[a], i can get result[b], just by flipping edge:

if a->b cost = 0, then b->a cost = 1, change = +1
if b->a cost = 1, then a->b cost = 0, change = -1

2 steps approach :
- pick any node (say 0) and compute its result using dfs - O(n)
- use dfs again to propogate results to all other nodes, using the relationship - O(n)

---- A tree with n nodes, has exactly n-1 edges, and there is exactly one path between any two nodes

List<int[]>[] graph;
int[] result;

public int[] minReversals(int n, int[][] edges) {

// build bi-directional graph with edge costs
// cost = 0 for original direction, cost = 1 for reverse direction

	graph = new List[n];
	for(int i = 0; i<n; i++) {
		graph[i] = new ArrayList<>();
	}

	for(int[] edge: edges) {
		int u = edge[0], v = edge[1];
		graph[u].add(new int[]{v, 0}); // original edge, cost = 0
		graph[v].add(new int[]{u, 1}); // reverse edge, cost = 1
	}

	result = new int[n];

	// Step 1: Calculate result for node 0 using DFS
	boolean[] visited = new boolean[n];
	result[0] = dfs(0, visited);


	// Step 2: Re-root to calculate results for all other nodes
	Arrays.fill(visited, false);
	reroot(0, visited);

	return result;
} 

private int dfs(int src, boolean[] visited) {
	visited[src] = true;
	int reversals = 0;
	for(int[] neighbor: graph[src]) {
		int nextNode = neighbor[0];
		int cost = neighbor[1];
		if(!visited[nextNode]) {
			reversals += cost + dfs(nextNode, visited);
		}	
	}
	return reversals;
}

private void reroot(int node, boolean[] visited) {
	visited[node] = true;
	for(int[] neighbor: graph[node]) {
		int nextNode = neighbor[0];
		int cost = neighbor[1]; // 0 -> original or 1 -> reversed
		if(!visited[nextNode]) {
		// if cost = 0, means original => result[nextNode] = result[node] + 1 => node -> nextNode so to reach node from nextNode i.e. node<-nextNode, there is cost=1
		// if cost = 1, means reversed => result[nextNode] = result[node] - 1;
			result[nextNode] = result[node] + (1 - 2 * cost);
			reroot(nextNode, visited);
		}
	}
}



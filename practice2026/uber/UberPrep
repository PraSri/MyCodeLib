Time & space complexity = O(n)

public String nearestPalindrome(String n) {
	int len = n.length()/2;
	int i = len%2==0 ? len/2-1 : len/2;
	long firstHalf = Long.parseLong(n.substring(0, i+1));

	// all possibilities
	long p1 = palin(firstHalf, len%2==0);
	long p2 = palin(firstHalf + 1, len%2 ==0);
	long p3 = palin(firstHalf - 1, len%2==0);
	long p4 = (long) (Math.pow(10, len-1) - 1);
	long p5 = (long) (Math.pow(10, len-1) + 1);

	List<Long> possibilities = List.of(p1,p2,p3,p4,p5);

	// find candidate with minimum difference and minimum value
	long diff = Long.MAX_VALUE, res = 0 , nl = Long.parseLong(n);

	for(long cand : possibilities) {
		if(cand == nl) continue;
		if(Math.abs(cand - nl) < diff) {
			diff = Math.abs(cand - nl);
			res = cand;
		} else if(Math.abs(cand-nl) == diff) {
			res = Math.min(res, cand);
		}
	}

	return String.valueOf(res);

}

private long palin(long left, boolean even) {
	long res = left;
	if(!even) left = left/10;
	while(left > 0) {
		res = res*10 + (left%10);
		left = left/10;
	}
	return res;
}



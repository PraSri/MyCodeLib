MinCostGridWithArrows

import java.util.*;

public class MinCostGridWithArrows {

    // Directions: up, down, left, right and their corresponding row, col deltas
    private static final int[] dRow = {-1, 1, 0, 0};
    private static final int[] dCol = {0, 0, -1, 1};
    private static final char[] dirChars = {'U', 'D', 'L', 'R'};

    public static int minCost(char[][] grid) {
        int n = grid.length;
        int m = grid[0].length;

        // Distance matrix, initialize with a large value
        int[][] dist = new int[n][m];
        for (int[] row : dist) {
            Arrays.fill(row, Integer.MAX_VALUE);
        }
        dist[0][0] = 0;

        // Deque for 0-1 BFS
        Deque<int[]> deque = new ArrayDeque<>();
        deque.addFirst(new int[]{0, 0});

        while (!deque.isEmpty()) {
            int[] cell = deque.pollFirst();
            int r = cell[0];
            int c = cell[1];
            int currentCost = dist[r][c];

            // If we already reached destination, we can optionally break early
            if (r == n - 1 && c == m - 1) {
                // Not breaking because there might be a better path? No, 0-1 BFS guarantees first time we pop destination is optimal.
                // But careful: we might have popped it earlier with a non-optimal distance? Actually in 0-1 BFS, when we pop a node, its distance is final.
                // So we can break.
                break;
            }

            // Explore all 4 neighbors
            for (int i = 0; i < 4; i++) {
                int nr = r + dRow[i];
                int nc = c + dCol[i];

                // Check bounds
                if (nr < 0 || nr >= n || nc < 0 || nc >= m) continue;

                // Cost for this move: 0 if moving in the direction of the current cell's arrow, else 1
                int moveCost = (grid[r][c] == dirChars[i]) ? 0 : 1;
                int newCost = currentCost + moveCost;

                if (newCost < dist[nr][nc]) {
                    dist[nr][nc] = newCost;
                    if (moveCost == 0) {
                        deque.addFirst(new int[]{nr, nc}); // 0-cost -> front
                    } else {
                        deque.addLast(new int[]{nr, nc});  // 1-cost -> back
                    }
                }
            }
        }

        return dist[n - 1][m - 1];
    }

    // Example usage
    public static void main(String[] args) {
        char[][] grid = {
            {'R', 'R', 'D'},
            {'L', 'D', 'D'},
            {'U', 'U', 'R'}
        };
        // Expected answer: 2 (path: (0,0)->(0,1) cost 0, (0,1)->(0,2) cost 0, (0,2)->(1,2) cost 1, (1,2)->(2,2) cost 1)
        System.out.println("Minimum cost: " + minCost(grid));
    }
}




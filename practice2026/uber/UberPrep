PriorityQueue solution: O(nlogn)

public int longestSubarray(int[] nums, int limit) {

	PriorityQueue<int[]> maxHeap = new PriorityQueue<>((a, b) -> Integer.compare(b[0], a[0]));
	PriorityQueue<int[]> minHeap = new PriorityQueue<>((a,b) -> Integer.compare(a[0], b[0]));

	int left = 0;
	int maxLength = 0;

	for(int right = 0; right<nums.length; right++) {
		minHeap.offer(new int[]{nums[right], right});
		maxHeap.offer(new int[]{nums[right], right});

		// if diff exceeds limit, move left pointer forward
		while(maxHeap.peek()[0] - minHeap.peek()[0] > limit) {
			left++;
			// lazy removal, if index is out of window
			while(maxHeap.peek()[1] < left) {
				maxHeap.poll();
			}
			while(minHeap.peek()[1] < left) {
				minHeap.poll();
			}
		}
		maxLength = right - left + 1;
	}

	return maxLength;

}


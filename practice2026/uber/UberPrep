class UnionFind{
	int[] parent;
	int[] rank;
	UnionFind(int n) {
	this.parent = new int[n];
	this.rank = new int[n];
		for(int i = 0;i<n;i++) {
			parent[i] = i;
			rank[i] = 1;
		}
	}

	public int find(int x) {
		if(parent[x] != x) {
			parent[x] = find(parent[x]);
		}
	return parent[x];
	}

	public boolean union(int x, int y) {
		int rootX = find(x);
		int rootY = find(y);
		if(rootX == rootY) {
			return false;
		}
		if(rank[x] > rank[y]) {
			parent[y] = x;
			rank[x] = rank[x] + rank[y];
		} else {
			parent[x] = y;
			rank[y] = rank[y] + ranl[x];
		}
		return true;
	}

}


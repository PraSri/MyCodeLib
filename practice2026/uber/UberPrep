ex routes[0] = [1,5,7], means 0th bus travel by route 1->5->7->1->5->7....

output - least number of buses to travel from source to target

Input: routes = [[1,2,7],[3,6,7]], source = 1, target = 6
Output: 2 => routes bus 0 - [1 -> 2 -> 7], bus 1 - [7->3->6]

public int numBusesToDestination(int[][] routes, int source, int target) {
	Map<Integer, List<Integer>> map = new HashMap<>();
	Set<Intger> visitedBus = new HashSet<>();
	Dequeu<int[]> queue = new ArrayDeque<>();

	// each bus stop is a node - O(M*K)
	for(int i = 0;i<routes.length;i++) {
		for(int stop: routes[i]) {
			if(!map.contains(stop)) {
				map.put(stop, new ArrayList<>());
			}
			map.get(stop).add(i);
		}
	}

    // stop, busCount
	queue.add(new int[]{source, 0});

	// O(M*K*M)
	while(!queue.isEmpty()) {

		int[] current = queue.poll();
		int stop = current[0];
		int busCount = current[1];

		if(stop == target) {
			return busCount;
		}

		if(map.containsKey(stop)) {
			for(int bus : map.get(stop)) {
				if(!visitedBus.contains(bus)) {
					for(int s: routes[bus]) {
						queue.add(new int[] {s, busCount+1});
					}
				}
				visitedBus.add(bus);
			}
		}

	}

	return -1;
}

Complexity:
Time - O(M^2 * K) - M = size of routes, K = maximum size of routes[i]
Space - O(M*K)

6. Alien Dictionary

public String alienDictionary(List<String> words) {
	// graph
	// indegree array
	// set for unique characters

	Map<Character, Set<Character>> adjList = new HashMap<>();
	Map<Character, Integer> indegree = new HashMap<>();
	Set<Character> uniqueCharacters = new HashSet<>();

	// early return empty string by eliminating scenarios

	if(words == null || words.isEmpty()) return "";


	// initialize graph, indegree, set

	for(String w: words) {
		for(char c: w.toCharArray()) {
			uniqueCharacters.add(c);
			indegree.putIfAbsent(c, 0);
			adjList.putIfAbsent(c, new HashSet<>());
		}
	}

	// build graph from word pairs comparisons - remember words are lexicographically sorted

	for(int i = 0; i < words.size() - 1; i++) {
		String curr = words.get(i);
		String next = words.get(i+1);
		if(curr.length() > next.length() && curr.startsWith(next)) {
			return "";
		}
		int minLen = Math.min(curr.length(), next.length());
		for(int j = 0;j<minLen; j++) {
			char u = curr.charAt(j);
			char v = next.charAt(j);
			if(u != v) {
				if(adjList.get(u).add(v)) {
					indegree.put(v, indegree.getOrDefault(v, 0) + 1);
				}
				break;
			}

		}
	}

	// apply topological sorting for getting character ordering
	Queue<Character> queue = new LinkedList<>();
	StringBuilder res = new StringBuilder();
	for(char c: uniqueCharacters) {
		if(indegree.get(c) == 0) {
			queue.add(c);
		}
	}

	while(!queue.isEmpty()) {
		char curr = queue.poll();
		res.append(curr);
		for(char neigh: adjList.getOrDefault(curr, Collections.emptySet())) {
			indegree.put(neigh, indegree.getOrDefault(neigh, 0) - 1);
			if(indegree.getOrDefault(neigh, 0) == 0) {
				queue.add(neigh);
			}
		}
	}

	if(res.length() < uniqueCharacters.size()) { 
		return "";
	}

	return res.toString();

}


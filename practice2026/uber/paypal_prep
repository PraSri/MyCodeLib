 Question:
	- Circular cipher based question. You need to decode the string passed you with the prvoided value of k.
	=> each letter in string shifts by a fixed number of positions k

public String decode(String text, int k) {
	StringBuilder result = new StringBuilder();
	k = k%26;
	for(char c: text.toCharArray) {
		if(Character.isLetter(c)) {
			char base = Character.isUpperCase(c) ? 'A' : 'a';
			char decodedChar = (char) ((c - base - k + 26) % 26 + base);
			result.append(decodedChar);
		} else {
			result.append(c);
		}
	}
	return result.toString();
}

